generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // "admin" or "user"
  createdAt DateTime @default(now())
}

model RegistroKm {
  id            Int       @id @default(autoincrement())
  numero        Int?
  data          DateTime
  placa         String
  veiculo       String
  motorista     String
  departamento  String
  destino       String
  finalidade    String
  kmInicial     Float
  kmFinal       Float
  kmPercorrido  Float
  combustivel   String
  litros        Float?
  valorLitro    Float?
  valorTotal    Float?
  kmLitro       Float?
  posto         String?
  observacoes   String?
  createdAt     DateTime  @default(now())

  @@index([data])
  @@index([placa])
  @@index([motorista])
}
