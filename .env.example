# Banco de dados Turso (libSQL)
TURSO_DATABASE_URL="libsql://seu-banco-seu-usuario-turso.turso.io"
TURSO_AUTH_TOKEN="seu-token-aqui"

# URL da aplicação (Next.js)
NEXTAUTH_URL="http://localhost:3000"

# Secret para NextAuth.js (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET="sua-chave-secreta-aqui"

# Resend API (envio de email)
RESEND_API_KEY="re_xxxxxxxxx"
